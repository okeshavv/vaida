# VAIDA Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── General ──────────────────────────────────────────────────────
ENVIRONMENT=development           # "development" | "production"
DATABASE_URL=sqlite:///./vaida.db # Use postgresql+asyncpg://... for production

# ── Auth ─────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_use_secrets_token_hex_32
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_HOURS=168

# OTP bypass — set to False in production!
OTP_BYPASS=True
OTP_BYPASS_CODE=123456
OTP_TTL_SECONDS=300

# ── Encryption ───────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=CHANGE_ME_use_secrets_token_hex_32

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── SMS Provider ─────────────────────────────────────────────────
# Twilio: SMS_PROVIDER_KEY=ACCOUNT_SID:AUTH_TOKEN
# MSG91:  SMS_PROVIDER_KEY=your_authkey
SMS_PROVIDER=twilio
SMS_PROVIDER_KEY=
SMS_FROM_NUMBER=+1XXXXXXXXXX   # Twilio sender number

# ── CORS (production only — dev allows all origins) ──────────────
# Comma-separated frontend URLs
ALLOWED_ORIGINS=https://vaida.app,https://www.vaida.app

# ── Uploads ──────────────────────────────────────────────────────
UPLOADS_DIR=./uploads

# ── Epidemiological Alerts ────────────────────────────────────────
EPI_ALERT_THRESHOLD=15

# ── Blockchain ───────────────────────────────────────────────────
BLOCKCHAIN_ENABLED=True

# ── External Services ────────────────────────────────────────────
GOOGLE_TTS_KEY=
JITSI_DOMAIN=meet.jit.si

# ── Monitoring (optional) ────────────────────────────────────────
SENTRY_DSN=
MLFLOW_TRACKING_URI=
